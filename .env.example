# ── LLM ──────────────────────────────────────────────────────────────────────
# Hugging Face model to serve with vLLM.
# Qwen2.5-7B is ungated — no HF_TOKEN required.
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Required only for gated models (e.g. meta-llama/Llama-3.1-8B-Instruct).
# Leave blank if using Qwen.
HF_TOKEN=

# ── vLLM tuning ───────────────────────────────────────────────────────────────
# How much of GPU 0's VRAM vLLM may use (0.0–1.0). 0.85 is a safe default.
VLLM_GPU_MEMORY_UTILIZATION=0.85

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3

# Host directory holding the downloaded HF cache (bge-m3). Mounted read-only into
# the app container. Shared, world-readable, on the big /data disk — NOT /home.
HF_CACHE_DIR=/data/shared/neurospin-llm/hf

# Host directory for the Qdrant vector DB (988 chunks). Shared on /data — NOT /home.
QDRANT_DATA_DIR=/data/shared/neurospin-llm/qdrant

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=neurospin_wiki

# ── RAG parameters ────────────────────────────────────────────────────────────
# Number of wiki chunks to retrieve per query.
RAG_TOP_K=5

# ── Ports (change if any conflict with existing services) ─────────────────────
QDRANT_PORT=6333
VLLM_PORT=8000
APP_PORT=8080
