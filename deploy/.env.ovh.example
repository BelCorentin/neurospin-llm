# OVH environment — copy to .env.ovh and fill in your values
# Then: docker compose -f docker-compose.ovh.yml --env-file .env.ovh up -d

# ── SSH tunnel target (NeuroSpin cluster) ──────────────────────────────────
# User and hostname for the cluster SSH jump host
CLUSTER_USER=cbel
CLUSTER_HOST=ext1.idris.fr        # or your actual SSH alias resolved hostname

# ── Service URLs (via tunnel, reachable from Docker via host.docker.internal)
VLLM_BASE_URL=http://host.docker.internal:8000/v1
QDRANT_URL=http://host.docker.internal:6333

# ── Model config ──────────────────────────────────────────────────────────
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBED_MODEL=BAAI/bge-m3
QDRANT_COLLECTION=neurospin_wiki
RAG_TOP_K=5
